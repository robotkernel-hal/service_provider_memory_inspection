PTVERSION           = 2
NAME                = @PACKAGE@
VERSION             = @PACKAGE_VERSION@
DESCRIPTION         = robotkernel @PACKAGE@
MAINTAINER          = Robert Burger <robert.burger@dlr.de>
DOCUMENTATION       = https://rmintra01.robotic.dlr.de/wiki/Robotkernel/interface_memory_inspection
ARCHS               = @ARCHS@
SUPPORTED_LANGUAGES = C
C_INCLUDE_PATHS     = ${PKGROOT}/include/
C_LIB_PATHS         = ${PKGROOT}/lib/${ARCH}
C_LIBS              = 

[install]
build/${ARCH}/install/lib => lib/${ARCH}
doc/ => doc/
share/ => share/
*.h => include/@PACKAGE@/
build/sled11-x86-gcc4.x/interface_memory_inspection_ln_messages.h => include/@PACKAGE@/
