requires_version 0.2.43
# this include file can be customized with the following defines:
#   interface_memory_inspection_base
#     (optional) path to interface_memory_inspection base directory
#     e.g. /volume/software/robotkernel/packages/interface_memory_inspection/3.0.1
#     defaults to rmpm structure
#   interface_memory_inspection_libdir
#     (optional) add custom module search paths
#   interface_memory_inspection_mds
#     (optional) add custom message definition paths

defines
interface_memory_inspection_base: %(dirname %(dirname %(CURDIR)))
interface_memory_inspection_base_type: %(ifexists "%(interface_memory_inspection_base)/lib/libinterface_memory_inspection.so", "local_install", "rmpm_release")
interface_memory_inspection_libdir: %(ifeq "%(interface_memory_inspection_base_type)", "local_install", "%(interface_memory_inspection_base)/lib", "%(interface_memory_inspection_base)/lib/$(ARCH)")
add_message_definition_dir: %(interface_memory_inspection_base)/share/ln/message_definitions 

ifndef rk_interfaces: rk_interfaces: ""
rk_interfaces: %(rk_interfaces):%(interface_memory_inspection_libdir)

