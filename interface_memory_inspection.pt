PTVERSION           = 2
NAME                = interface_memory_inspection
VERSION             = 3.0.0
DESCRIPTION         = robotkernel memory inspection interface
MAINTAINER          = Robert Burger <robert.burger@dlr.de>
DOCUMENTATION       = https://rmintra01.robotic.dlr.de/wiki/robotkernel/interface_memory_inspection
ARCHS               = sled11-x86-gcc4.x, sled11-x86_64-gcc4.x, angstrom-armv7-gcc4.7, vxworks6.7-x86-gcc4.x, vxworks6.8-x86-gcc4.x, vxworks6.9-x86-gcc4.x, vxworks6.9.3-x86-gcc4.x, vxworks6.9.4-x86-gcc4.x, qnx6.3-x86-gcc3.3, qnx6.5-x86-gcc4.x, qnx6.5-x86-gcc4.x-gpp

[install]
build/${ARCH}/install/lib => lib/${ARCH}
doc/ => doc/
share/ => share/

